}<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHAWON TV LIVE - লোগো গ্রিড ডিজাইন</title>
    <style>
        body { background: #0f0f0f; color: #fff; font-family: sans-serif; margin: 0; }
        .header { text-align: center; padding: 20px; background: #1a1d29; border-bottom: 2px solid #ff0055; }
        .main-container { display: flex; flex-wrap: wrap; padding: 20px; gap: 20px; }
        #video-container { flex: 2; min-width: 300px; }
        video { width: 100%; height: 450px; border-radius: 10px; background: #000; }
        .sidebar { flex: 1; min-width: 300px; background: #1a1d29; padding: 15px; border-radius: 10px; height: 70vh; overflow-y: auto; }
        .channel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .channel-card { background: #fff; color: #000; padding: 10px; border-radius: 8px; text-align: center; cursor: pointer; transition: 0.3s; border: 2px solid transparent; }
        .channel-card:hover { transform: scale(1.05); box-shadow: 0 0 10px #00d4ff; border: 2px solid #ff0055; }
        .channel-logo { max-width: 100%; height: 50px; object-fit: contain; }
        .channel-name { font-size: 0.8em; margin-top: 5px; font-weight: bold; color: #ff0055; }
        h3 { border-bottom: 2px solid #ff0055; padding-bottom: 5px; color: #fff; }
    </style>
</head>
<body>

<div class="header"><h1>SHAWON TV LIVE</h1></div>

<div class="main-container">
    <div id="video-container">
        <video id="video" controls autoplay></video>
        <h3 id="channel-name" style="margin-top: 10px; color: #00d4ff;">চ্যানেল নির্বাচন করুন</h3>
    </div>

    <div class="sidebar">
        <h3>বাংলাদেশী চ্যানেল</h3>
        <div class="channel-grid">
            <!-- BTV -->
            <div class="channel-card" onclick="playChannel('https://owrcovcrpy.gpcdn.net/bpk-tv/1709/output/index.m3u8', 'BTV')">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e6/BTV_logo.png/200px-BTV_logo.png" alt="BTV" class="channel-logo">
                <div class="channel-name">BTV</div>
            </div>

            <!-- Somoy TV -->
            <div class="channel-card" onclick="playChannel('https://live.thebosstv.com:30443/dwlive/Somoy-TV/chunks.m3u8', 'Somoy TV')">
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/4e/Somoy_TV_logo.png" alt="Somoy TV" class="channel-logo">
                <div class="channel-name">SOMOY TV</div>
            </div>

            <!-- NTV -->
            <div class="channel-card" onclick="playChannel('https://owrcovcrpy.gpcdn.net/bpk-tv/1716/output/index.m3u8', 'NTV')">
                <img src="https://upload.wikimedia.org/wikipedia/en/thumb/f/f0/NTV_%28Bangladesh%29_logo.svg/1200px-NTV_%28Bangladesh%29_logo.svg.png" alt="NTV" class="channel-logo">
                <div class="channel-name">NTV</div>
            </div>

            <!-- Channel 24 -->
            <div class="channel-card" onclick="playChannel('https://owrcovcrpy.gpcdn.net/bpk-tv/1703/output/index.m3u8', 'Channel 24')">
                <img src="https://upload.wikimedia.org/wikipedia/en/thumb/3/3d/Channel_24_Bangladesh_logo.png/220px-Channel_24_Bangladesh_logo.png" alt="Channel 24" class="channel-logo">
                <div class="channel-name">CHANNEL 24</div>
            </div>

            <!-- Jamuna TV -->
            <div class="channel-card" onclick="playChannel('https://owrcovcrpy.gpcdn.net/bpk-tv/1701/output/index.m3u8', 'Jamuna TV')">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/16/Jamuna_TV.png/220px-Jamuna_TV.png" alt="Jamuna TV" class="channel-logo">
                <div class="channel-name">JAMUNA TV</div>
            </div>

            <!-- Independent TV -->
            <div class="channel-card" onclick="playChannel('https://owrcovcrpy.gpcdn.net/bpk-tv/1704/output/index.m3u8', 'Independent TV')">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/52/Independent_Television_%28Bangladesh%29_logo.svg/200px-Independent_Television_%28Bangladesh%29_logo.svg.png" alt="Independent TV" class="channel-logo">
                <div class="channel-name">INDEPENDENT</div>
            </div>
        </div>

        <h3 style="margin-top: 20px;">স্পোর্টস চ্যানেল</h3>
        <div class="channel-grid">
            <!-- T Sports -->
            <div class="channel-card" onclick="playChannel('http://198.195.239.50:8095/tsports/tracks-v1a1/mono.m3u8', 'T Sports')">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2f/T_Sports_Logo.png/220px-T_Sports_Logo.png" alt="T Sports" class="channel-logo">
                <div class="channel-name">T SPORTS</div>
            </div>

            <!-- Sony Ten 1 -->
            <div class="channel-card" onclick="playChannel('https://sm-monirul.top/toffee/play/sony_sports_1_hd.m3u8', 'Sony Ten 1 HD')">
                <img src="https://upload.wikimedia.org/wikipedia/en/thumb/5/5a/Sony_Ten_1_logo.png/220px-Sony_Ten_1_logo.png" alt="Sony Ten 1" class="channel-logo">
                <div class="channel-name">TEN 1 HD</div>
            </div>

            <!-- Sony Ten 2 -->
            <div class="channel-card" onclick="playChannel('https://sm-monirul.top/toffee/play/sony_sports_2_hd.m3u8', 'Sony Ten 2 HD')">
                <img src="https://upload.wikimedia.org/wikipedia/en/thumb/9/91/Sony_Ten_2_logo.png/220px-Sony_Ten_2_logo.png" alt="Sony Ten 2" class="channel-logo">
                <div class="channel-name">TEN 2 HD</div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script>
    var video = document.getElementById('video');
    var hls = new Hls();
    function playChannel(url, name) {
        document.getElementById('channel-name').innerText = "এখন চলছে: " + name;
        if (Hls.isSupported()) {
            hls.destroy();
            hls = new Hls();
            hls.loadSource(url);
            hls.attachMedia(video);
            video.play();
        }
    }
</script>
</body>
</html>
